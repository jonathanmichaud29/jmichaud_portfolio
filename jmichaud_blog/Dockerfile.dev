# ============================================================
# Dev only — NOT used in production
# Source is bind-mounted from the host at runtime.
# No build step — Vite dev server handles compilation on the fly.
# ============================================================
FROM node:22.15.0-alpine

# corepack reads packageManager field from package.json
RUN corepack enable

WORKDIR /app

# Dependencies are installed here at image build time.
# The anonymous volume in docker-compose.dev.yml ensures node_modules
# inside the container is NOT overwritten by the host bind mount.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
RUN pnpm install --frozen-lockfile

# Source is NOT copied here — it arrives via bind mount at runtime.
# This keeps the image reusable: source changes never require a rebuild.

ENV HOST=0.0.0.0
ENV PORT=4321

EXPOSE 4321

CMD ["pnpm", "dev", "--host", "0.0.0.0"]