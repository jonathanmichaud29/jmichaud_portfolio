---
/**
 * /series/[seriesSlug].astro
 *
 * CSS migration: series.css has been dissolved into Tailwind utility
 * classes inline on each element. No external stylesheet imports remain.
 */

export const prerender = true;

import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getItemListSchema, getBreadcrumbSchema } from "../../lib/schema";
import { SITE } from "../../config/site";

export async function getStaticPaths() {
  const [allSeries, allPosts] = await Promise.all([
    getCollection("series"),
    getCollection("blog", ({ data }) => !data.noindex),
  ]);

  return allSeries.map((series) => {
    const seriesPosts = allPosts.filter(
      (post) => post.data.series?.id === series.id
    );

    const orderedPosts = seriesPosts.sort(
      (a, b) => (a.data.seriesPart ?? 0) - (b.data.seriesPart ?? 0)
    );

    return {
      params: { seriesSlug: series.data.slug },
      props: { series, orderedPosts },
    };
  });
}

interface Props {
  series: CollectionEntry<"series">;
  orderedPosts: CollectionEntry<"blog">[];
}

const { series, orderedPosts } = Astro.props;
const { title, description, publishedAt, updatedAt, ogImage } = series.data;

const canonicalUrl = `${SITE.url}/series/${series.data.slug}`;

const itemListSchema = getItemListSchema(series, orderedPosts);
const breadcrumbSchema = getBreadcrumbSchema([
  { name: "Blog", path: "/blog" },
  { name: title, path: `/series/${series.data.slug}` },
]);
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
  schemaNodes={[itemListSchema, breadcrumbSchema]}
>
  <div class="max-w-[var(--width-prose)] mx-auto px-6">

    <!-- Breadcrumb -->
    <nav
      class="flex items-center flex-wrap gap-2 font-mono text-xs text-text-muted py-8 pb-6"
      aria-label="Breadcrumb"
    >
      <a href="/" class="text-text-muted hover:text-accent transition-colors duration-150">{SITE.name}</a>
      <span class="text-bg-border" aria-hidden="true">/</span>
      <a href="/blog" class="text-text-muted hover:text-accent transition-colors duration-150">Blog</a>
      <span class="text-bg-border" aria-hidden="true">/</span>
      <span
        aria-current="page"
        class="text-text-primary max-w-[32ch] whitespace-nowrap overflow-hidden text-ellipsis"
      >{title}</span>
    </nav>

    <!-- Series header -->
    <header class="pb-8 border-b border-bg-border mb-8">

      <!-- Meta row -->
      <div class="flex items-center flex-wrap gap-3 text-xs text-text-muted font-mono mb-4">
        <span class="font-mono text-xs text-accent bg-[rgba(63,185,80,0.1)] border border-[rgba(63,185,80,0.2)] rounded px-2 py-0.5 whitespace-nowrap">
          Series
        </span>
        <span class="text-bg-border">·</span>
        <span>
          {orderedPosts.length}
          {orderedPosts.length === 1 ? "part" : "parts"}
        </span>
        {series.data.status === "active" && (
          <>
            <span class="text-bg-border">·</span>
            <span class="inline-flex items-center gap-1 text-accent font-mono text-xs" aria-label="Series in progress">
              <span
                class="w-1.5 h-1.5 rounded-full bg-accent flex-shrink-0"
                style="animation: series-pulse 2s ease-in-out infinite;"
                aria-hidden="true"
              />
              Active
            </span>
          </>
        )}
        {series.data.repoUrl && (
          <>
            <span class="text-bg-border">·</span>
            <a
              href={series.data.repoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-muted hover:text-accent underline underline-offset-[3px] transition-colors duration-150"
            >GitHub</a>
          </>
        )}
        {series.data.demoUrl && (
          <>
            <span class="text-bg-border">·</span>
            <a
              href={series.data.demoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-muted hover:text-accent underline underline-offset-[3px] transition-colors duration-150"
            >Live demo</a>
          </>
        )}
      </div>

      <h1 class="text-[clamp(1.5rem,4vw,2.25rem)] font-semibold leading-[1.15] tracking-[-0.02em] mb-4">
        {title}
      </h1>
      <p class="text-lg text-text-muted leading-[1.6] max-w-[60ch] mb-6">
        {description}
      </p>

      <!-- Dates -->
      <div class="flex items-center flex-wrap gap-3 text-xs text-text-muted font-mono">
        <span>
          Started{" "}
          <time datetime={publishedAt.toISOString()}>
            {publishedAt.toLocaleDateString("en-CA", {
              year: "numeric",
              month: "short",
              day: "numeric",
            })}
          </time>
        </span>
        {updatedAt > publishedAt && (
          <>
            <span class="text-bg-border">·</span>
            <span>
              Updated{" "}
              <time datetime={updatedAt.toISOString()}>
                {updatedAt.toLocaleDateString("en-CA", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </time>
            </span>
          </>
        )}
      </div>
    </header>

    <!-- Parts list -->
    <ol class="flex flex-col gap-4 pb-24" aria-label="Series parts">
      {orderedPosts.map((post) => (
        <li>
          <article class="bg-bg-surface border border-bg-border rounded-lg p-6 flex flex-col gap-3 hover:border-accent transition-colors duration-150">

            <!-- Part meta -->
            <div class="flex items-center flex-wrap gap-3 text-xs text-text-muted font-mono">
              {post.data.seriesPart !== undefined && (
                <span class="font-mono text-xs text-accent font-medium">
                  Part {post.data.seriesPart}
                </span>
              )}
              <span class="text-bg-border">·</span>
              <time datetime={post.data.publishedAt.toISOString()}>
                {post.data.publishedAt.toLocaleDateString("en-CA", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </time>
              {post.data.readingTime !== undefined && (
                <>
                  <span class="text-bg-border">·</span>
                  <span>{post.data.readingTime} min read</span>
                </>
              )}
            </div>

            <h2 class="text-xl font-semibold leading-[1.3]">
              <a
                href={`/blog/${post.id}`}
                class="text-text-primary hover:text-accent transition-colors duration-150"
              >{post.data.title}</a>
            </h2>

            <p class="text-sm text-text-muted leading-[1.6]">
              {post.data.description}
            </p>

            {post.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-2 mt-1" aria-label="Tags">
                {post.data.tags.slice(0, 4).map((tag) => (
                  <span class="font-mono text-xs text-accent bg-[rgba(63,185,80,0.1)] border border-[rgba(63,185,80,0.2)] rounded px-2 py-0.5 whitespace-nowrap">
                    {tag}
                  </span>
                ))}
              </div>
            )}

          </article>
        </li>
      ))}
    </ol>

  </div>
</BaseLayout>
