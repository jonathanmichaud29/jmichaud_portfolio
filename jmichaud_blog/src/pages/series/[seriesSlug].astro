---
/**
 * /series/[seriesSlug].astro
 *
 * Series index page — one route per entry in the series collection.
 * Lists all published posts in the series in part order, with a header
 * showing the series title, description, and publication dates.
 *
 * Schema emitted:
 *   - ItemList  — ordered list of parts; Google can render this in SERPs
 *   - BreadcrumbList — site hierarchy signal
 *   (WebSite + Person are always injected by BaseLayout)
 *
 * og:type is "website" here, not "article" — this is a collection index
 * page, not a piece of authored content. No article:published_time.
 */

export const prerender = true;

import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getItemListSchema, getBreadcrumbSchema } from "../../lib/schema";
import { SITE } from "../../config/site";

// CSS: global tokens + reset loaded by BaseLayout.
// series.css: all series index page specific styles.
import "../../styles/series.css";

// ---------------------------------------------------------------------------
// getStaticPaths
//
// One route per series. Each route receives the series metadata and its
// ordered, published posts as props — no additional data fetching in the
// component below.
// ---------------------------------------------------------------------------
export async function getStaticPaths() {
  const [allSeries, allPosts] = await Promise.all([
    getCollection("series"),
    getCollection("blog", ({ data }) => !data.noindex),
  ]);

  return allSeries.map((series) => {
    // Collect all published posts that reference this series.
    const seriesPosts = allPosts.filter(
      (post) => post.data.series?.id === series.id
    );

    // Order by seriesPart ascending (pt1 first).
    // Posts without seriesPart sort to the front (treated as 0) — this is a
    // content authoring error, not a valid state, but we degrade gracefully
    // rather than throwing at build time.
    const orderedPosts = seriesPosts.sort(
      (a, b) => (a.data.seriesPart ?? 0) - (b.data.seriesPart ?? 0)
    );

    return {
      params: { seriesSlug: series.data.slug },
      props: { series, orderedPosts },
    };
  });
}

// ---------------------------------------------------------------------------
// Props
// ---------------------------------------------------------------------------
interface Props {
  series: CollectionEntry<"series">;
  orderedPosts: CollectionEntry<"blog">[];
}

const { series, orderedPosts } = Astro.props;
const { title, description, publishedAt, updatedAt, ogImage } = series.data;

const canonicalUrl = `${SITE.url}/series/${series.data.slug}`;

// --- Schema ---
// ItemList: ordered series TOC — what Google can render in SERPs.
// BreadcrumbList: site hierarchy signal.
// Both are passed to BaseLayout via schemaNodes; WebSite + Person are
// injected by BaseLayout automatically.
const itemListSchema = getItemListSchema(series, orderedPosts);
const breadcrumbSchema = getBreadcrumbSchema([
  { name: "Blog", path: "/blog" },
  { name: title, path: `/series/${series.data.slug}` },
]);
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
  schemaNodes={[itemListSchema, breadcrumbSchema]}
>
  <div class="container-prose">
    <!-- ---------------------------------------------------------------- -->
    <!-- Breadcrumb                                                        -->
    <!-- ---------------------------------------------------------------- -->
    <nav class="series-breadcrumb" aria-label="Breadcrumb">
      <a href="/">{SITE.name}</a>
      <span class="series-breadcrumb-sep" aria-hidden="true">/</span>
      <a href="/blog">Blog</a>
      <span class="series-breadcrumb-sep" aria-hidden="true">/</span>
      <span aria-current="page">{title}</span>
    </nav>

    <!-- ---------------------------------------------------------------- -->
    <!-- Series header                                                     -->
    <!-- ---------------------------------------------------------------- -->
    <header class="series-header">
      <div class="meta series-meta">
        <span class="tag">Series</span>
        <span class="meta-sep">·</span>
        <span>
          {orderedPosts.length}
          {orderedPosts.length === 1 ? "part" : "parts"}
        </span>
        {
          series.data.status === "active" && (
            <>
              <span class="meta-sep">·</span>
              <span class="series-active-badge" aria-label="Series in progress">
                <span class="series-active-dot" aria-hidden="true" />
                Active
              </span>
            </>
          )
        }
        {
          series.data.repoUrl && (
            <>
              <span class="meta-sep">·</span>
              <a
                href={series.data.repoUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="series-meta-link"
              >
                GitHub
              </a>
            </>
          )
        }
        {
          series.data.demoUrl && (
            <>
              <span class="meta-sep">·</span>
              <a
                href={series.data.demoUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="series-meta-link"
              >
                Live demo
              </a>
            </>
          )
        }
      </div>

      <h1 class="series-title">{title}</h1>
      <p class="series-description">{description}</p>

      <div class="meta series-dates">
        <span>
          Started{" "}
          <time datetime={publishedAt.toISOString()}>
            {
              publishedAt.toLocaleDateString("en-CA", {
                year: "numeric",
                month: "short",
                day: "numeric",
              })
            }
          </time>
        </span>
        {
          updatedAt > publishedAt && (
            <>
              <span class="meta-sep">·</span>
              <span>
                Updated{" "}
                <time datetime={updatedAt.toISOString()}>
                  {updatedAt.toLocaleDateString("en-CA", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </time>
              </span>
            </>
          )
        }
      </div>
    </header>

    <!-- ---------------------------------------------------------------- -->
    <!-- Parts list                                                        -->
    <!-- ---------------------------------------------------------------- -->
    <ol class="series-parts" aria-label="Series parts">
      {
        orderedPosts.map((post) => (
          <li class="series-part">
            <article class="card series-part-card">
              <div class="meta series-part-meta">
                {post.data.seriesPart !== undefined && (
                  <span class="series-part-number">
                    Part {post.data.seriesPart}
                  </span>
                )}
                <span class="meta-sep">·</span>
                <time datetime={post.data.publishedAt.toISOString()}>
                  {post.data.publishedAt.toLocaleDateString("en-CA", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </time>
                {post.data.readingTime !== undefined && (
                  <>
                    <span class="meta-sep">·</span>
                    <span>{post.data.readingTime} min read</span>
                  </>
                )}
              </div>

              <h2 class="series-part-title">
                <a href={`/blog/${post.id}`}>{post.data.title}</a>
              </h2>

              <p class="series-part-description">{post.data.description}</p>

              {post.data.tags.length > 0 && (
                <div class="series-part-tags" aria-label="Tags">
                  {post.data.tags.slice(0, 4).map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )}
            </article>
          </li>
        ))
      }
    </ol>
  </div>
</BaseLayout>
