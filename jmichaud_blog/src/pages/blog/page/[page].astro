---
/**
 * /blog/page/[page].astro — Blog listing, pages 2+
 *
 * Handles /blog/page/2, /blog/page/3, etc.
 * Page 1 is always /blog (index.astro) — this route explicitly skips
 * generating page 1 to prevent a duplicate-content URL.
 *
 * ⚠️  IMPORTANT: page.url.prev on page 2 (generated by Astro's paginate())
 * returns "/blog/page/1" — a URL that does NOT exist because we filter
 * page 1 out of getStaticPaths. The Pagination component corrects this:
 * pageHref(1) always returns basePath ("/blog"), never "/blog/page/1".
 * However, page.url.prev is still "/blog/page/1" in the raw prop — do
 * NOT use page.url.prev directly for prev-page navigation. Always go
 * through pageHref(page.currentPage - 1) as Pagination.astro does.
 *
 * SYNC REQUIREMENT: PAGE_SIZE must match blog/index.astro exactly.
 * Both files paginate the same query (getAllPostsSortedDesc) with the
 * same page size. If they diverge, page boundaries shift and users
 * see duplicate or missing posts across page 1 and page 2.
 * Consider extracting PAGE_SIZE to src/config/site.ts if it needs to
 * change frequently.
 */

export const prerender = true;

import type { GetStaticPaths, Page } from "astro";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Pagination from "../../../components/Pagination.astro";
import BlogPostCard from "../../../components/BlogPostCard.astro";
import { getBreadcrumbSchema } from "../../../lib/schema";
import { getAllPostsSortedDesc } from "../../../lib/content/queries";
import { SITE } from "../../../config/site";

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getAllPostsSortedDesc();

  // paginate() generates paths starting at page=1.
  // Filter out page 1 — its canonical URL is /blog, not /blog/page/1.
  // Serving both /blog and /blog/page/1 with the same content is a
  // duplicate-content defect.
  const allPages = paginate(allPosts, { pageSize: SITE.blog.pageSize });
  return allPages.filter(({ params }) => Number(params.page) > 1);
}) satisfies GetStaticPaths;

interface Props {
  page: Page<CollectionEntry<"blog">>;
}

const { page } = Astro.props;

const canonicalUrl = `${SITE.url}/blog/page/${page.currentPage}`;

const breadcrumbSchema = getBreadcrumbSchema([
  { name: "Blog", path: "/blog" },
  { name: `Page ${page.currentPage}`, path: `/blog/page/${page.currentPage}` },
]);
---

<BaseLayout
  title={`Blog — Page ${page.currentPage}`}
  description={`Blog posts on full-stack development and engineering — page ${page.currentPage} of ${page.lastPage}.`}
  canonicalUrl={canonicalUrl}
  schemaNodes={[breadcrumbSchema]}
>
  <div class="max-w-[var(--width-prose)] mx-auto px-6">
    <!-- Breadcrumb -->
    <nav
      class="flex items-center flex-wrap gap-2 font-mono text-xs text-text-muted py-8 pb-6"
      aria-label="Breadcrumb"
    >
      <a
        href="/"
        class="text-text-muted hover:text-accent transition-colors duration-150"
        >{SITE.name}</a
      >
      <span class="text-bg-border" aria-hidden="true">/</span>
      <a
        href="/blog"
        class="text-text-muted hover:text-accent transition-colors duration-150"
        >Blog</a
      >
      <span class="text-bg-border" aria-hidden="true">/</span>
      <span aria-current="page" class="text-text-primary">
        Page {page.currentPage}
      </span>
    </nav>

    <!-- Page header -->
    <header class="pb-8 border-b border-bg-border mb-8">
      <p class="font-mono text-xs text-accent uppercase tracking-[0.1em] mb-3">
        Writing
      </p>
      <h1
        class="text-[clamp(1.5rem,4vw,2.25rem)] font-semibold leading-[1.15] tracking-[-0.02em] mb-3"
      >
        Blog
      </h1>
      <p class="text-base text-text-muted leading-[1.65]">
        Page {page.currentPage} of {page.lastPage}
        <span class="font-mono text-xs text-text-muted ml-2">
          · {page.total}
          {page.total === 1 ? "post" : "posts"} total
        </span>
      </p>
    </header>

    <!-- Post list -->
    <ol class="flex flex-col gap-4" aria-label="Blog posts">
      {
        page.data.map((post) => (
          <li>
            <BlogPostCard post={post} />
          </li>
        ))
      }
    </ol>

    <!-- Pagination -->
    <Pagination page={page} basePath="/blog" />
  </div>
</BaseLayout>
