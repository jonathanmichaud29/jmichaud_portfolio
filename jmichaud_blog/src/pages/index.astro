---
/**
 * index.astro — Homepage
 *
 * CSS migration: utilities.css dissolved into Tailwind utility classes
 * inline on each element. Duplicate .btn-primary / .btn-secondary
 * definitions removed. No <style> block remains.
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { SITE } from "../config/site";
import { getLatestFeedItems } from "../lib/content/queries";

const allSeries = await getCollection("series");
const activeSeries = allSeries
  .filter((s) => s.data.status === "active")
  .sort((a, b) => b.data.updatedAt.getTime() - a.data.updatedAt.getTime())
  .at(0) ?? null;

let activeSeriesLatestPost: CollectionEntry<"blog"> | null = null;
if (activeSeries) {
  const seriesPosts = await getCollection(
    "blog",
    ({ data }) => !data.noindex && data.series?.id === activeSeries.id
  );
  activeSeriesLatestPost = seriesPosts.sort(
    (a, b) => (b.data.seriesPart ?? 0) - (a.data.seriesPart ?? 0)
  ).at(0) ?? null;
}

const latestPosts = await getLatestFeedItems(3);

const techCategories = [
  {
    label: "Frontend",
    items: ["Astro", "React", "TypeScript", "Tailwind CSS"],
  },
  {
    label: "Backend",
    items: ["Node.js", "PHP", "REST APIs", "SSR"],
  },
  {
    label: "Infrastructure",
    items: ["Docker", "Kubernetes", "ArgoCD", "Nginx"],
  },
  {
    label: "Tooling & DevOps",
    items: ["HashiCorp Vault", "Helm", "GitHub Actions", "pnpm"],
  },
];
---

<BaseLayout
  title={SITE.title}
  description={SITE.description}
>

  <!-- -------------------------------------------------------------------- -->
  <!-- Hero                                                                   -->
  <!-- -------------------------------------------------------------------- -->
  <section class="py-24 section">
    <div class="max-w-[var(--width-prose)] mx-auto px-6">
      <p class="font-mono text-xs text-accent uppercase tracking-[0.1em] mb-4">
        Full-Stack Developer
      </p>
      <h1 class="text-[clamp(1.875rem,5vw,3.5rem)] font-semibold leading-[1.1] tracking-[-0.02em] mb-6 text-text-primary">
        {SITE.name}
      </h1>
      <p class="text-lg text-text-muted max-w-[52ch] leading-[1.65] mb-8">
        I build complete systems — from infrastructure to interface.
        Currently available for permanent roles where ownership and craft matter.
      </p>
      <div class="flex gap-4 flex-wrap">
        <a
          href="/about"
          class="inline-flex items-center bg-accent text-bg px-6 py-3 rounded-md text-sm font-semibold hover:bg-accent-dim active:scale-[0.98] transition-[background-color,transform] duration-150"
        >
          About me
        </a>
        <a
          href="/blog"
          class="inline-flex items-center border border-bg-border text-text-primary px-6 py-3 rounded-md text-sm font-medium hover:border-accent hover:text-accent transition-[border-color,color] duration-150"
        >
          Read the blog
        </a>
      </div>
    </div>
  </section>

  <!-- -------------------------------------------------------------------- -->
  <!-- Currently Working On                                                   -->
  <!-- -------------------------------------------------------------------- -->
  {activeSeries && (
    <section class="section pb-24" aria-labelledby="working-heading">
      <div class="max-w-[var(--width-wide)] mx-auto px-6">
        <p class="font-mono text-xs text-accent uppercase tracking-[0.1em] my-4">
          Current blog series writing on
        </p>
        <div class="bg-bg-surface border border-bg-border rounded-lg p-6 hover:border-accent transition-colors duration-150">

          <!-- Row 1: Meta + Active indicator -->
          <div class="grid grid-cols-[1fr_auto] gap-x-8 gap-y-2 mb-4">
            <!-- Meta (col 1) -->
            <div class="flex items-center flex-wrap gap-3 text-xs text-text-muted font-mono">
              <span class="font-mono text-xs text-accent bg-[rgba(63,185,80,0.1)] border border-[rgba(63,185,80,0.2)] rounded px-2 py-0.5 whitespace-nowrap">
                Series
              </span>
              <span class="text-bg-border">·</span>
              <span>
                {activeSeries.data.order.length}{" "}
                {activeSeries.data.order.length === 1 ? "part" : "parts"} published
              </span>
              {activeSeries.data.demoUrl && (
                <>
                  <span class="text-bg-border">·</span>
                  <a
                    href={activeSeries.data.demoUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-text-muted underline underline-offset-[3px] hover:text-accent transition-colors duration-150"
                  >Live demo</a>
                </>
              )}
              {activeSeries.data.repoUrl && (
                <>
                  <span class="text-bg-border">·</span>
                  <a
                    href={activeSeries.data.repoUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-text-muted underline underline-offset-[3px] hover:text-accent transition-colors duration-150"
                  >GitHub</a>
                </>
              )}
            </div>

            <!-- Active indicator (col 2) -->
            <div class="hidden sm:flex items-center gap-2" aria-hidden="true">
              <span
                class="w-2 h-2 rounded-full bg-accent flex-shrink-0"
                style="animation: pulse 2s ease-in-out infinite;"
              />
              <span class="font-mono text-xs text-accent uppercase tracking-[0.08em]">Active</span>
            </div>
          </div>

          <!-- Row 2: Title + description | Buttons -->
          <div class="grid grid-cols-1 sm:grid-cols-[1fr_auto] gap-x-8 gap-y-6 items-center">
            <!-- Title + description (col 1) -->
            <div class="min-w-0">
              <h2 class="text-xl font-semibold mb-3">{activeSeries.data.title}</h2>
              <p class="text-base text-text-muted leading-[1.6] max-w-[60ch]">
                {activeSeries.data.description}
              </p>
            </div>

            <!-- Actions (col 2) -->
            <div class="flex flex-col gap-3 flex-shrink-0 ">
              <a
                href={`/series/${activeSeries.data.slug}`}
                class="inline-flex items-center justify-center border border-bg-border text-text-primary px-6 py-3 rounded-md text-sm font-medium hover:border-accent hover:text-accent transition-[border-color,color] duration-150"
              >
                View series
              </a>
              {activeSeriesLatestPost && (
                <a
                  href={`/blog/${activeSeriesLatestPost.id}`}
                  class="inline-flex items-center justify-center bg-accent text-bg px-6 py-3 rounded-md text-sm font-semibold hover:bg-accent-dim active:scale-[0.98] transition-[background-color,transform] duration-150"
                >
                  Read latest part
                </a>
              )}
            </div>
          </div>

        </div>
      </div>
    </section>
  )}

  <!-- -------------------------------------------------------------------- -->
  <!-- Tech stack                                                             -->
  <!-- -------------------------------------------------------------------- -->
  <section class="section border-t border-bg-border" aria-labelledby="tech-heading">
    <div class="max-w-[var(--width-wide)] mx-auto px-6 py-12">
      <p class="font-mono text-xs text-accent uppercase tracking-[0.1em] mb-4">Technologies</p>
      <h2 id="tech-heading" class="text-2xl font-semibold mb-8">What I work with</h2>
      <div class="grid grid-cols-[repeat(auto-fit,minmax(200px,1fr))] gap-8">
        {techCategories.map((cat) => (
          <div>
            <h3 class="font-mono text-xs text-text-muted uppercase tracking-[0.08em] mb-4 font-medium">
              {cat.label}
            </h3>
            <ul class="flex flex-col gap-2" role="list">
              {cat.items.map((item) => (
                <li class="text-sm text-text-primary py-2 border-b border-bg-border flex items-center gap-2 before:content-['▹'] before:text-accent before:font-mono before:text-xs before:flex-shrink-0">
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- -------------------------------------------------------------------- -->
  <!-- Latest from the blog                                                   -->
  <!-- -------------------------------------------------------------------- -->
  {latestPosts.length > 0 && (
    <section class="section border-t border-bg-border" aria-labelledby="blog-heading">
      <div class="max-w-[var(--width-wide)] mx-auto px-6 py-12">
        <div class="flex items-end justify-between mb-8 gap-4">
          <div>
            <p class="font-mono text-xs text-accent uppercase tracking-[0.1em] mb-4">Writing</p>
            <h2 id="blog-heading" class="text-2xl font-semibold">Latest posts</h2>
          </div>
          <a
            href="/blog"
            class="font-mono text-sm text-text-muted whitespace-nowrap hover:text-accent transition-colors duration-150 pb-0.5"
            aria-label="View all blog posts"
          >
            All posts →
          </a>
        </div>

        <div class="grid grid-cols-[repeat(auto-fit,minmax(280px,1fr))] gap-6">
          {latestPosts.map((item) => (
            <article class="bg-bg-surface border border-bg-border rounded-lg p-6 flex flex-col gap-3 hover:border-accent transition-colors duration-150">

              <!-- Meta -->
              <div class="flex items-center flex-wrap gap-3 text-xs text-text-muted font-mono">
                {item.kind === "series" ? (
                  <span class="font-mono text-xs text-accent bg-[rgba(63,185,80,0.1)] border border-[rgba(63,185,80,0.2)] rounded px-2 py-0.5 whitespace-nowrap">
                    Series · {item.partCount} {item.partCount === 1 ? "part" : "parts"}
                  </span>
                ) : (
                  <span class="font-mono text-xs text-accent bg-[rgba(63,185,80,0.1)] border border-[rgba(63,185,80,0.2)] rounded px-2 py-0.5 whitespace-nowrap">
                    Post
                  </span>
                )}
                <span class="text-bg-border">·</span>
                <time datetime={item.publishedAt.toISOString()}>
                  {item.publishedAt.toLocaleDateString("en-CA", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </time>
                {item.kind === "standalone" && item.post.data.readingTime && (
                  <>
                    <span class="text-bg-border">·</span>
                    <span>{item.post.data.readingTime} min read</span>
                  </>
                )}
              </div>

              <h3 class="text-lg font-semibold leading-[1.3]">
                <a
                  href={item.href}
                  class="text-text-primary hover:text-accent transition-colors duration-150"
                >{item.title}</a>
              </h3>

              <p class="text-sm text-text-muted leading-[1.6] flex-1">
                {item.description}
              </p>

              <div class="flex flex-col gap-3 flex-shrink-0 ">
               
                <a
                  href={`${item.href}`}
                  class="self-start inline-flex items-center justify-center bg-accent text-bg px-6 py-3 rounded-md text-sm font-semibold hover:bg-accent-dim active:scale-[0.98] transition-[background-color,transform] duration-150"
                >
                  Read more
                </a>
              </div>

            </article>
          ))}
        </div>
      </div>
    </section>
  )}

</BaseLayout>
