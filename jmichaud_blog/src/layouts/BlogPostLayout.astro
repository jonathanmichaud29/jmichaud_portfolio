---
/**
 * BlogPostLayout.astro
 *
 * Layout for blog-post typed entries.
 *
 * CSS migration: post-layout.css and post-prose.css have been dissolved
 * into Tailwind utility classes inline on each element.
 * No external stylesheet imports remain in this layout.
 */

import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import { getArticleSchema, getBreadcrumbSchema } from "../lib/schema";
import { SITE } from "../config/site";

interface Props {
  post: CollectionEntry<"blog"> & { data: { type: "blog-post" } };
  series: CollectionEntry<"series"> | null;
}

const { post, series } = Astro.props;
const {
  title,
  description,
  publishedAt,
  updatedAt,
  readingTime,
  ogImage,
  canonicalUrl: canonicalOverride,
  noindex,
} = post.data;

const canonicalUrl = canonicalOverride ?? `${SITE.url}/blog/${post.id}`;

const articleSchema = getArticleSchema(post, series, canonicalUrl);

const breadcrumbItems = [
  { name: "Blog", path: "/blog" },
  ...(series
    ? [{ name: series.data.title, path: `/series/${series.data.slug}` }]
    : []),
  { name: title, path: `/blog/${post.id}` },
];
const breadcrumbSchema = getBreadcrumbSchema(breadcrumbItems);
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
  noindex={noindex}
  ogType="article"
  articlePublishedTime={publishedAt.toISOString()}
  articleModifiedTime={(updatedAt ?? publishedAt).toISOString()}
  schemaNodes={[articleSchema, breadcrumbSchema]}
>
  <div class="max-w-[var(--width-prose)] mx-auto px-6">
    <!-- Breadcrumb -->
    <nav
      class="flex items-center flex-wrap gap-2 font-mono text-xs text-text-muted py-8 pb-6"
      aria-label="Breadcrumb"
    >
      <a
        href="/"
        class="text-text-muted hover:text-accent transition-colors duration-150"
        >{SITE.name}</a
      >
      <span class="text-bg-border" aria-hidden="true">/</span>
      <a
        href="/blog"
        class="text-text-muted hover:text-accent transition-colors duration-150"
        >Blog</a
      >
      {
        series && (
          <>
            <span class="text-bg-border" aria-hidden="true">
              /
            </span>
            <a
              href={`/series/${series.data.slug}`}
              class="text-text-muted hover:text-accent transition-colors duration-150"
            >
              {series.data.title}
            </a>
          </>
        )
      }
      <span class="text-bg-border" aria-hidden="true">/</span>
      <span
        aria-current="page"
        class="text-text-primary max-w-[32ch] whitespace-nowrap overflow-hidden text-ellipsis"
        >{title}</span
      >
    </nav>

    <article>
      <!-- Post header -->
      <header class="pb-8 border-b border-bg-border mb-8">
        <h1
          class="text-[clamp(1.5rem,4vw,2.25rem)] font-semibold leading-[1.15] tracking-[-0.02em] mb-4"
        >
          {title}
        </h1>
        <p class="text-lg text-text-muted leading-[1.6] mb-6 max-w-[60ch]">
          {description}
        </p>

        <!-- Meta row -->
        <div
          class="flex items-center flex-wrap gap-3 text-xs text-text-muted font-mono"
        >
          <time datetime={publishedAt.toISOString()}>
            {
              publishedAt.toLocaleDateString("en-CA", {
                year: "numeric",
                month: "short",
                day: "numeric",
              })
            }
          </time>
          {
            updatedAt && (
              <>
                <span class="text-bg-border">·</span>
                <span>
                  Updated{" "}
                  <time datetime={updatedAt.toISOString()}>
                    {updatedAt.toLocaleDateString("en-CA", {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                    })}
                  </time>
                </span>
              </>
            )
          }
          {
            readingTime !== undefined && (
              <>
                <span class="text-bg-border">·</span>
                <span>{readingTime} min read</span>
              </>
            )
          }
        </div>
      </header>

      <!-- Post body -->
      <div class="prose prose-invert max-w-none pb-24">
        <slot />
      </div>
    </article>
  </div>
</BaseLayout>
