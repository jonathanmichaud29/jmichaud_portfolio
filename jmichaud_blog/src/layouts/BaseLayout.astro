---
/**
 * BaseLayout.astro
 *
 * Root layout for every page. Provides:
 *   - Full <html> document shell
 *   - <head> meta strategy (canonical, OG, Twitter Card, JSON-LD)
 *   - Site header + main content slot + footer
 *   - Global CSS (tokens, reset, keyframes — global.css only)
 *
 * CSS migration: header.css, footer.css, and utilities.css have been
 * dissolved into Tailwind utility classes inline on each element.
 * Only global.css remains as an external stylesheet.
 */

import { SITE } from "../config/site";
import {
  composeSchema,
  serializeSchema,
  getWebSiteSchema,
  getPersonSchema,
} from "../lib/schema";

import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  noindex?: boolean;
  schemaNodes?: ReturnType<typeof composeSchema>["@graph"][number][];
  ogType?: "website" | "article";
  articlePublishedTime?: string;
  articleModifiedTime?: string;
}

const {
  title,
  description = SITE.description,
  canonicalUrl = Astro.url.href,
  ogImage = SITE.defaultOgImage,
  noindex = false,
  schemaNodes = [],
  ogType = "website",
  articlePublishedTime,
  articleModifiedTime,
} = Astro.props;

const pageTitle = `${title} | ${SITE.name}`;

const ogImageAbsolute = ogImage.startsWith("http")
  ? ogImage
  : `${SITE.url}${ogImage}`;

const baseNodes = [getWebSiteSchema(), getPersonSchema()];
const schema = composeSchema([...baseNodes, ...schemaNodes] as Parameters<
  typeof composeSchema
>[0]);
---

<!doctype html>
<html lang="en-CA">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta
      name="robots"
      content={noindex ? "noindex, nofollow" : "index, follow"}
    />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="any" />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_CA" />
    {
      ogType === "article" && articlePublishedTime && (
        <meta property="article:published_time" content={articlePublishedTime} />
      )
    }
    {
      ogType === "article" && articleModifiedTime && (
        <meta property="article:modified_time" content={articleModifiedTime} />
      )
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <Fragment set:html={serializeSchema(schema)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-bg text-text-primary font-sans">

    <!-- Skip link -->
    <a
      href="#main-content"
      class="absolute -top-full left-4 z-[200] bg-accent text-bg px-4 py-2 rounded-b-md text-sm font-semibold transition-[top] duration-100 focus:top-0"
    >
      Skip to content
    </a>

    <!-- ------------------------------------------------------------------ -->
    <!-- Header                                                               -->
    <!-- ------------------------------------------------------------------ -->
    <header
      id="site-header"
      aria-label="Site header"
      class="fixed top-0 left-0 right-0 z-[100] h-[var(--height-header)] bg-bg/85 backdrop-blur-[12px] border-b border-bg-border transition-transform duration-[250ms] ease-[ease]"
    >
      <div class="max-w-[var(--width-wide)] mx-auto px-6 h-full flex items-center justify-between">

        <!-- Name mark -->
        <a
          href="/"
          class="font-mono text-sm font-medium text-text-primary tracking-[0.01em] flex items-center gap-px group"
          aria-label={`${SITE.name} — home`}
        >
          <span class="group-hover:text-accent transition-colors duration-150">{SITE.name}</span>
          <span
            class="text-accent font-normal ml-px"
            style="animation: blink 1.1s step-end infinite;"
            aria-hidden="true"
          >|</span>
        </a>

        <!-- Nav -->
        <nav aria-label="Main navigation">
          <ul role="list" class="flex items-center gap-6">
            <li>
              <a href="/about" class="text-sm text-text-muted font-medium hover:text-text-primary transition-colors duration-150">About</a>
            </li>
            <li>
              <a href="/blog" class="text-sm text-text-muted font-medium hover:text-text-primary transition-colors duration-150">Blog</a>
            </li>
            <li>
              <a href="#contact" class="text-sm text-text-muted font-medium hover:text-text-primary transition-colors duration-150">Contact</a>
            </li>
          </ul>
        </nav>

      </div>
    </header>

    <!-- ------------------------------------------------------------------ -->
    <!-- Page content                                                         -->
    <!-- ------------------------------------------------------------------ -->
    <main id="main-content">
      <slot />
    </main>

    <!-- ------------------------------------------------------------------ -->
    <!-- Footer                                                               -->
    <!-- ------------------------------------------------------------------ -->
    <footer
      id="contact"
      aria-label="Contact and site footer"
      class="bg-bg-surface border-t border-bg-border mt-24"
    >
      <div class="max-w-[var(--width-wide)] mx-auto px-6 pt-16 pb-8">

        <div class="grid grid-cols-1 md:grid-cols-[1fr_280px] gap-16 items-start">

          <!-- Contact form -->
          <section class="footer-contact" aria-labelledby="contact-heading">
            <h2 id="contact-heading" class="text-xl font-semibold mb-2">Get in touch</h2>
            <p class="text-sm text-text-muted mb-6">
              Open to permanent opportunities. Response within 48 hours.
            </p>
            <form
              class="flex flex-col gap-4 max-w-[480px]"
              action="/api/contact"
              method="POST"
              aria-label="Contact form"
            >
              <div class="flex flex-col gap-1">
                <label
                  for="contact-name"
                  class="text-xs font-medium text-text-muted uppercase tracking-[0.08em] font-mono"
                >Name</label>
                <input
                  id="contact-name"
                  type="text"
                  name="name"
                  required
                  autocomplete="name"
                  placeholder="Your name"
                  class="bg-bg border border-bg-border rounded-md px-4 py-3 text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:border-accent transition-colors duration-150"
                />
              </div>
              <div class="flex flex-col gap-1">
                <label
                  for="contact-email"
                  class="text-xs font-medium text-text-muted uppercase tracking-[0.08em] font-mono"
                >Email</label>
                <input
                  id="contact-email"
                  type="email"
                  name="email"
                  required
                  autocomplete="email"
                  placeholder="your@email.com"
                  class="bg-bg border border-bg-border rounded-md px-4 py-3 text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:border-accent transition-colors duration-150"
                />
              </div>
              <div class="flex flex-col gap-1">
                <label
                  for="contact-message"
                  class="text-xs font-medium text-text-muted uppercase tracking-[0.08em] font-mono"
                >Message</label>
                <textarea
                  id="contact-message"
                  name="message"
                  rows="4"
                  required
                  placeholder="What are you working on?"
                  class="bg-bg border border-bg-border rounded-md px-4 py-3 text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:border-accent transition-colors duration-150 resize-y"
                ></textarea>
              </div>
              <button
                type="submit"
                class="self-start bg-accent text-bg border-none rounded-md px-6 py-3 text-sm font-semibold cursor-pointer hover:bg-accent-dim active:scale-[0.98] transition-[background-color,transform] duration-150"
              >
                Send message
              </button>
            </form>
          </section>

          <!-- Footer right: links + resume -->
          <div class="flex flex-col gap-8 pt-0.5">

            <div>
              <h3 class="text-xs font-medium text-text-muted uppercase tracking-[0.08em] font-mono mb-3">Links</h3>
              <ul role="list" class="flex flex-col gap-2">
                <li>
                  <a
                    href={SITE.social.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="GitHub profile (opens in new tab)"
                    class="text-sm text-text-muted hover:text-text-primary transition-colors duration-150 inline-flex items-center gap-2 before:content-['→'] before:text-accent before:font-mono before:text-xs"
                  >
                    GitHub
                  </a>
                </li>
                <li>
                  <a
                    href={SITE.social.linkedin}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="LinkedIn profile (opens in new tab)"
                    class="text-sm text-text-muted hover:text-text-primary transition-colors duration-150 inline-flex items-center gap-2 before:content-['→'] before:text-accent before:font-mono before:text-xs"
                  >
                    LinkedIn
                  </a>
                </li>
              </ul>
            </div>

            <a
              href="/resume.pdf"
              download
              class="inline-flex items-center justify-center gap-2 border border-bg-border rounded-md px-4 py-3 text-sm font-medium text-text-primary hover:border-accent hover:text-accent transition-[border-color,color] duration-150 w-full"
              aria-label="Download resume as PDF"
            >
              <span class="font-mono text-accent" aria-hidden="true">↓</span>
              Download résumé
            </a>

          </div>
        </div>

        <!-- Bottom bar -->
        <div class="mt-12 pt-6 border-t border-bg-border text-xs text-text-muted">
          <p>
            &copy; {new Date().getFullYear()}
            {SITE.name}. Built with
            <a
              href="https://astro.build"
              target="_blank"
              rel="noopener noreferrer"
              class="underline underline-offset-[3px] hover:text-text-primary transition-colors duration-150"
            >
              Astro
            </a>.
          </p>
        </div>

      </div>
    </footer>

    <script src="../scripts/header-scroll.ts"></script>
  </body>
</html>
