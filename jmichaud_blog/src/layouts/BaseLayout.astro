---
/**
 * BaseLayout.astro
 *
 * Root layout for every page. Provides:
 *   - Full <html> document shell
 *   - <head> meta strategy (canonical, OG, Twitter Card, JSON-LD)
 *   - Site header + main content slot + footer
 *   - Global CSS (tokens, reset, header, footer, utilities)
 *
 * Page-specific schemas (Article, BreadcrumbList, ItemList) are composed
 * at the call site and passed in via the `schemaNodes` prop, which this
 * layout merges into the base WebSite + Person graph.
 */

import { SITE } from "../config/site";
import {
  composeSchema,
  serializeSchema,
  getWebSiteSchema,
  getPersonSchema,
} from "../lib/schema";

// Global CSS — import order is the cascade order.
// Vite deduplicates these across layouts at build time.
import "../styles/global.css";
import "../styles/header.css";
import "../styles/footer.css";
import "../styles/utilities.css";

interface Props {
  /**
   * Page-specific title. Combined with SITE.name in <title>:
   *   "About" → "About | Jonathan Levesque Michaud"
   * For the homepage, pass SITE.title ("Full-Stack Developer") so the
   * title reads as a descriptor rather than a redundant name repetition.
   */
  title: string;

  /** Falls back to SITE.description when omitted. */
  description?: string;

  /**
   * Canonical URL override. Defaults to current page URL.
   * Set only when overriding, e.g. for syndicated content with an
   * origin URL that differs from the publication URL.
   */
  canonicalUrl?: string;

  /** OG image absolute path. Defaults to SITE.defaultOgImage. */
  ogImage?: string;

  /** Renders "noindex, nofollow" robots meta when true. */
  noindex?: boolean;

  /**
   * Additional schema nodes merged into the @graph.
   * BaseLayout always injects WebSite + Person. Pass Article,
   * BreadcrumbList, or ItemList from the calling page/layout.
   */
  schemaNodes?: ReturnType<typeof composeSchema>["@graph"][number][];

  /**
   * og:type — defaults to "website".
   * Pass "article" on blog post pages to unlock article:* OG tags.
   */
  ogType?: "website" | "article";

  /** ISO 8601 string. Only rendered when ogType === "article". */
  articlePublishedTime?: string;

  /** ISO 8601 string. Only rendered when ogType === "article". */
  articleModifiedTime?: string;
}

const {
  title,
  description = SITE.description,
  canonicalUrl = Astro.url.href,
  ogImage = SITE.defaultOgImage,
  noindex = false,
  schemaNodes = [],
  ogType = "website",
  articlePublishedTime,
  articleModifiedTime,
} = Astro.props;

const pageTitle = `${title} | ${SITE.name}`;

// Resolve OG image to an absolute URL.
// Accepts both absolute URLs (for external images) and root-relative paths.
const ogImageAbsolute = ogImage.startsWith("http")
  ? ogImage
  : `${SITE.url}${ogImage}`;

// Compose schema graph: base nodes always present + page-level nodes passed in.
// composeSchema() strips individual @context values and hoists one to the graph.
const baseNodes = [getWebSiteSchema(), getPersonSchema()];
const schema = composeSchema([...baseNodes, ...schemaNodes] as Parameters<
  typeof composeSchema
>[0]);
---

<!doctype html>
<html lang="en-CA">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary meta -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta
      name="robots"
      content={noindex ? "noindex, nofollow" : "index, follow"}
    />

    <!-- Canonical — present even when self-referencing (prevents duplicates) -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="any" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_CA" />
    {
      ogType === "article" && articlePublishedTime && (
        <meta
          property="article:published_time"
          content={articlePublishedTime}
        />
      )
    }
    {
      ogType === "article" && articleModifiedTime && (
        <meta property="article:modified_time" content={articleModifiedTime} />
      )
    }

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- JSON-LD schema graph -->
    <Fragment set:html={serializeSchema(schema)} />

    <!--
      Fonts: Inter (display + body) + JetBrains Mono (code + name mark).
      Preconnect first, then load — avoids render-blocking on initial paint.
    -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <!-- ------------------------------------------------------------------ -->
    <!-- Header                                                               -->
    <!-- ------------------------------------------------------------------ -->
    <header id="site-header" aria-label="Site header">
      <div class="header-inner">
        <a href="/" class="header-name" aria-label={`${SITE.name} — home`}>
          <span class="name-text">{SITE.name}</span>
          <span class="cursor" aria-hidden="true">|</span>
        </a>

        <nav aria-label="Main navigation">
          <ul role="list">
            <li><a href="/about">About</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="#contact">Contact</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <!-- ------------------------------------------------------------------ -->
    <!-- Page content                                                         -->
    <!-- ------------------------------------------------------------------ -->
    <main id="main-content">
      <slot />
    </main>

    <!-- ------------------------------------------------------------------ -->
    <!-- Footer — id="contact" is the anchor target for the header nav link  -->
    <!-- ------------------------------------------------------------------ -->
    <footer id="contact" aria-label="Contact and site footer">
      <div class="footer-inner">
        <div class="footer-grid">
          <!-- Contact form -->
          <section class="footer-contact" aria-labelledby="contact-heading">
            <h2 id="contact-heading">Get in touch</h2>
            <p class="footer-contact-sub">
              Open to permanent opportunities. Response within 48 hours.
            </p>
            <form
              class="contact-form"
              action="/api/contact"
              method="POST"
              aria-label="Contact form"
            >
              <div class="form-row">
                <label for="contact-name">Name</label>
                <input
                  id="contact-name"
                  type="text"
                  name="name"
                  required
                  autocomplete="name"
                  placeholder="Your name"
                />
              </div>
              <div class="form-row">
                <label for="contact-email">Email</label>
                <input
                  id="contact-email"
                  type="email"
                  name="email"
                  required
                  autocomplete="email"
                  placeholder="your@email.com"
                />
              </div>
              <div class="form-row">
                <label for="contact-message">Message</label>
                <textarea
                  id="contact-message"
                  name="message"
                  rows="4"
                  required
                  placeholder="What are you working on?"></textarea>
              </div>
              <button type="submit" class="btn-submit">Send message</button>
            </form>
          </section>

          <!-- Footer right: links + resume -->
          <div class="footer-links">
            <div class="footer-social">
              <h3>Links</h3>
              <ul role="list">
                <li>
                  <a
                    href={SITE.social.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="GitHub profile (opens in new tab)"
                  >
                    GitHub
                  </a>
                </li>
                <li>
                  <a
                    href={SITE.social.linkedin}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="LinkedIn profile (opens in new tab)"
                  >
                    LinkedIn
                  </a>
                </li>
              </ul>
            </div>

            <div class="footer-resume">
              <a
                href="/resume.pdf"
                download
                class="resume-download"
                aria-label="Download resume as PDF"
              >
                <span class="resume-icon" aria-hidden="true">↓</span>
                Download résumé
              </a>
            </div>
          </div>
        </div>

        <div class="footer-bottom">
          <p>
            &copy; {new Date().getFullYear()}
            {SITE.name}. Built with
            <a
              href="https://astro.build"
              target="_blank"
              rel="noopener noreferrer"
            >
              Astro
            </a>.
          </p>
        </div>
      </div>
    </footer>

    <!--
      Header scroll behaviour — hide on scroll down, reveal on scroll up.
      Astro bundles this as a separate client chunk; it is not inlined.
    -->
    <script src="../scripts/header-scroll.ts"></script>
  </body>
</html>
