---
import { SITE } from "../config/site";
import {
  composeSchema,
  serializeSchema,
  getWebSiteSchema,
  getPersonSchema,
} from "../lib/schema";

interface Props {
  // Page title — combined with SITE.name in <title> tag.
  // Pass the page-specific portion only: "About" → "About | Jonathan Levesque Michaud"
  // For the homepage, pass SITE.title ("Full-Stack Developer") so the <title>
  // reads as a descriptor, not a redundant repetition of the name.
  title: string;
  description?: string;
  // Canonical URL override — defaults to current page URL.
  // Set explicitly only when overriding (e.g. syndicated content).
  canonicalUrl?: string;
  // OG image — defaults to SITE.defaultOgImage.
  ogImage?: string;
  // When true, renders "noindex, nofollow" robots meta.
  noindex?: boolean;
  // Additional schema nodes to merge into the @graph.
  // BaseLayout always injects WebSite + Person. Page-level schemas
  // (Article, BreadcrumbList, ItemList) are passed in here.
  schemaNodes?: ReturnType<typeof composeSchema>["@graph"][number][];
  // og:type — defaults to "website". Pass "article" on blog post pages.
  ogType?: "website" | "article";
  // Article-specific OG tags — only rendered when ogType === "article"
  articlePublishedTime?: string;
  articleModifiedTime?: string;
}

const {
  title,
  description = SITE.description,
  canonicalUrl = Astro.url.href,
  ogImage = SITE.defaultOgImage,
  noindex = false,
  schemaNodes = [],
  ogType = "website",
  articlePublishedTime,
  articleModifiedTime,
} = Astro.props;

const pageTitle = `${title} | ${SITE.name}`;
const ogImageAbsolute = ogImage.startsWith("http")
  ? ogImage
  : `${SITE.url}${ogImage}`;

// Compose schema graph: base nodes always present + page-level nodes passed in.
// stripping @context from individual nodes happens inside composeSchema().
const baseNodes = [getWebSiteSchema(), getPersonSchema()];
const schema = composeSchema([...baseNodes, ...schemaNodes] as Parameters<typeof composeSchema>[0]);
---

<!doctype html>
<html lang="en-CA">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary meta -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta
      name="robots"
      content={noindex ? "noindex, nofollow" : "index, follow"}
    />

    <!-- Canonical — always present, even when self-referencing -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="any" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_CA" />
    {
      ogType === "article" && articlePublishedTime && (
        <meta
          property="article:published_time"
          content={articlePublishedTime}
        />
      )
    }
    {
      ogType === "article" && articleModifiedTime && (
        <meta
          property="article:modified_time"
          content={articleModifiedTime}
        />
      )
    }

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- JSON-LD schema graph -->
    <Fragment set:html={serializeSchema(schema)} />

    <!-- Fonts: Inter (display + body) + JetBrains Mono (code + name mark) -->
    <!-- Preconnect first, then load — avoids render-blocking -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <!-- ------------------------------------------------------------------ -->
    <!-- Header                                                               -->
    <!-- ------------------------------------------------------------------ -->
    <header id="site-header" aria-label="Site header">
      <div class="header-inner">
        <a href="/" class="header-name" aria-label={`${SITE.name} — home`}>
          <span class="name-text">{SITE.name}</span><span class="cursor" aria-hidden="true">|</span>
        </a>

        <nav aria-label="Main navigation">
          <ul role="list">
            <li><a href="/about">About</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="#contact">Contact</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <!-- ------------------------------------------------------------------ -->
    <!-- Page content                                                         -->
    <!-- ------------------------------------------------------------------ -->
    <main id="main-content">
      <slot />
    </main>

    <!-- ------------------------------------------------------------------ -->
    <!-- Footer — id="contact" is the anchor target for the header nav link  -->
    <!-- ------------------------------------------------------------------ -->
    <footer id="contact" aria-label="Contact and site footer">
      <div class="footer-inner">

        <div class="footer-grid">

          <!-- Contact form -->
          <section class="footer-contact" aria-labelledby="contact-heading">
            <h2 id="contact-heading">Get in touch</h2>
            <p class="footer-contact-sub">
              Open to permanent opportunities. Response within 48 hours.
            </p>
            <form
              class="contact-form"
              action="/api/contact"
              method="POST"
              aria-label="Contact form"
            >
              <div class="form-row">
                <label for="contact-name">Name</label>
                <input
                  id="contact-name"
                  type="text"
                  name="name"
                  required
                  autocomplete="name"
                  placeholder="Your name"
                />
              </div>
              <div class="form-row">
                <label for="contact-email">Email</label>
                <input
                  id="contact-email"
                  type="email"
                  name="email"
                  required
                  autocomplete="email"
                  placeholder="your@email.com"
                />
              </div>
              <div class="form-row">
                <label for="contact-message">Message</label>
                <textarea
                  id="contact-message"
                  name="message"
                  rows="4"
                  required
                  placeholder="What are you working on?"
                ></textarea>
              </div>
              <button type="submit" class="btn-submit">Send message</button>
            </form>
          </section>

          <!-- Footer right: links + resume -->
          <div class="footer-links">
            <div class="footer-social">
              <h3>Links</h3>
              <ul role="list">
                <li>
                  <a
                    href={SITE.social.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="GitHub profile (opens in new tab)"
                  >
                    GitHub
                  </a>
                </li>
                <li>
                  <a
                    href={SITE.social.linkedin}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="LinkedIn profile (opens in new tab)"
                  >
                    LinkedIn
                  </a>
                </li>
              </ul>
            </div>

            <div class="footer-resume">
              <a href="/resume.pdf" download class="resume-download" aria-label="Download resume as PDF">
                <span class="resume-icon" aria-hidden="true">↓</span>
                Download résumé
              </a>
            </div>
          </div>

        </div>

        <div class="footer-bottom">
          <p>
            &copy; {new Date().getFullYear()}
            {SITE.name}. Built with
            <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>.
          </p>
        </div>

      </div>
    </footer>

    <!-- ------------------------------------------------------------------ -->
    <!-- Header scroll behaviour — hide on scroll down, show on scroll up    -->
    <!-- ------------------------------------------------------------------ -->
    <script>
      (() => {
        const header = document.getElementById("site-header");
        if (!header) return;

        let lastY = window.scrollY;
        let ticking = false;

        // Threshold before hiding kicks in — prevents hiding on tiny scrolls
        // (e.g. pull-to-refresh overshoot on mobile)
        const HIDE_THRESHOLD = 80;

        function update() {
          const currentY = window.scrollY;
          const delta = currentY - lastY;

          if (currentY < HIDE_THRESHOLD) {
            // Always show near the top
            header.removeAttribute("data-hidden");
          } else if (delta > 4) {
            // Scrolling down — hide
            header.setAttribute("data-hidden", "");
          } else if (delta < -4) {
            // Scrolling up — show
            header.removeAttribute("data-hidden");
          }

          lastY = currentY;
          ticking = false;
        }

        window.addEventListener(
          "scroll",
          () => {
            if (!ticking) {
              requestAnimationFrame(update);
              ticking = true;
            }
          },
          { passive: true }
        );
      })();
    </script>
  </body>
</html>

<style is:global>
  /* ------------------------------------------------------------------ */
  /* Design tokens                                                        */
  /* ------------------------------------------------------------------ */
  :root {
    --bg:           #0d1117;
    --bg-surface:   #161b22;
    --bg-border:    #30363d;
    --text-primary: #e6edf3;
    --text-muted:   #7d8590;
    --accent:       #3fb950;
    --accent-dim:   #2ea043;

    --font-sans: "Inter", system-ui, sans-serif;
    --font-mono: "JetBrains Mono", "Fira Code", monospace;

    /* Type scale */
    --text-xs:   0.75rem;
    --text-sm:   0.875rem;
    --text-base: 1rem;
    --text-lg:   1.125rem;
    --text-xl:   1.25rem;
    --text-2xl:  1.5rem;
    --text-3xl:  1.875rem;
    --text-4xl:  2.25rem;

    /* Spacing */
    --space-1:  0.25rem;
    --space-2:  0.5rem;
    --space-3:  0.75rem;
    --space-4:  1rem;
    --space-6:  1.5rem;
    --space-8:  2rem;
    --space-12: 3rem;
    --space-16: 4rem;
    --space-24: 6rem;

    /* Layout */
    --max-prose: 760px;
    --max-wide:  1100px;
    --header-h:  64px;
  }

  /* ------------------------------------------------------------------ */
  /* Reset + base                                                         */
  /* ------------------------------------------------------------------ */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    background-color: var(--bg);
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    scroll-behavior: smooth;
  }

  body {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  #main-content {
    flex: 1;
    /* Offset for fixed header so content never hides behind it */
    padding-top: var(--header-h);
  }

  img, video {
    max-width: 100%;
    height: auto;
    display: block;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  ul, ol {
    list-style: none;
  }

  button, input, textarea, select {
    font: inherit;
  }

  /* ------------------------------------------------------------------ */
  /* Header                                                               */
  /* ------------------------------------------------------------------ */
  #site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--header-h);
    background-color: rgba(13, 17, 23, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--bg-border);

    /* Smooth transition for hide/show */
    transition: transform 0.25s ease;
  }

  /* JS adds this attribute when scrolling down */
  #site-header[data-hidden] {
    transform: translateY(-100%);
  }

  .header-inner {
    max-width: var(--max-wide);
    margin: 0 auto;
    padding: 0 var(--space-6);
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* Name mark — JetBrains Mono, blinking cursor signature element */
  .header-name {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-primary);
    letter-spacing: 0.01em;
    display: flex;
    align-items: center;
    gap: 1px;
  }

  .header-name:hover .name-text {
    color: var(--accent);
    transition: color 0.15s ease;
  }

  /* Blinking cursor — the signature element */
  .cursor {
    color: var(--accent);
    animation: blink 1.1s step-end infinite;
    font-weight: 400;
    margin-left: 1px;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cursor { animation: none; opacity: 1; }
  }

  /* Nav links */
  #site-header nav ul {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  #site-header nav a {
    font-size: var(--text-sm);
    color: var(--text-muted);
    transition: color 0.15s ease;
    font-weight: 500;
  }

  #site-header nav a:hover {
    color: var(--text-primary);
  }

  /* ------------------------------------------------------------------ */
  /* Footer                                                               */
  /* ------------------------------------------------------------------ */
  footer {
    background-color: var(--bg-surface);
    border-top: 1px solid var(--bg-border);
    margin-top: var(--space-24);
  }

  .footer-inner {
    max-width: var(--max-wide);
    margin: 0 auto;
    padding: var(--space-16) var(--space-6) var(--space-8);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--space-16);
    align-items: start;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-12);
    }
  }

  /* Contact section */
  .footer-contact h2 {
    font-size: var(--text-xl);
    font-weight: 600;
    margin-bottom: var(--space-2);
  }

  .footer-contact-sub {
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-bottom: var(--space-6);
  }

  /* Contact form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 480px;
  }

  .form-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .form-row label {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: var(--font-mono);
  }

  .form-row input,
  .form-row textarea {
    background-color: var(--bg);
    border: 1px solid var(--bg-border);
    border-radius: 6px;
    padding: var(--space-3) var(--space-4);
    color: var(--text-primary);
    font-size: var(--text-sm);
    transition: border-color 0.15s ease;
    resize: vertical;
  }

  .form-row input::placeholder,
  .form-row textarea::placeholder {
    color: var(--text-muted);
  }

  .form-row input:focus,
  .form-row textarea:focus {
    outline: none;
    border-color: var(--accent);
  }

  .btn-submit {
    align-self: flex-start;
    background-color: var(--accent);
    color: #0d1117;
    border: none;
    border-radius: 6px;
    padding: var(--space-3) var(--space-6);
    font-size: var(--text-sm);
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.15s ease, transform 0.1s ease;
  }

  .btn-submit:hover {
    background-color: var(--accent-dim);
  }

  .btn-submit:active {
    transform: scale(0.98);
  }

  /* Footer links column */
  .footer-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    padding-top: var(--space-2);
  }

  .footer-social h3 {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: var(--font-mono);
    margin-bottom: var(--space-3);
  }

  .footer-social ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-social a {
    font-size: var(--text-sm);
    color: var(--text-muted);
    transition: color 0.15s ease;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .footer-social a::before {
    content: "→";
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .footer-social a:hover {
    color: var(--text-primary);
  }

  /* Resume download */
  .resume-download {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    border: 1px solid var(--bg-border);
    border-radius: 6px;
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-primary);
    transition: border-color 0.15s ease, color 0.15s ease;
    width: 100%;
    justify-content: center;
  }

  .resume-download:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .resume-icon {
    font-family: var(--font-mono);
    color: var(--accent);
  }

  /* Footer bottom bar */
  .footer-bottom {
    margin-top: var(--space-12);
    padding-top: var(--space-6);
    border-top: 1px solid var(--bg-border);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .footer-bottom a {
    color: var(--text-muted);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .footer-bottom a:hover {
    color: var(--text-primary);
  }

  /* ------------------------------------------------------------------ */
  /* Shared utility classes                                               */
  /* ------------------------------------------------------------------ */

  /* Content width containers */
  .container-prose {
    max-width: var(--max-prose);
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  .container-wide {
    max-width: var(--max-wide);
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  /* Section vertical spacing */
  .section {
    padding: var(--space-24) 0;
  }

  .section + .section {
    padding-top: 0;
  }

  /* Tag pills — used on blog cards, skill grid */
  .tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    background-color: rgba(63, 185, 80, 0.1);
    border: 1px solid rgba(63, 185, 80, 0.2);
    border-radius: 4px;
    padding: 2px var(--space-2);
    white-space: nowrap;
  }

  /* Muted metadata line */
  .meta {
    font-size: var(--text-xs);
    color: var(--text-muted);
    font-family: var(--font-mono);
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .meta-sep {
    color: var(--bg-border);
  }

  /* Card surface */
  .card {
    background-color: var(--bg-surface);
    border: 1px solid var(--bg-border);
    border-radius: 8px;
    padding: var(--space-6);
    transition: border-color 0.15s ease;
  }

  .card:hover {
    border-color: var(--accent);
  }

  /* Headings */
  h1, h2, h3, h4 {
    font-family: var(--font-sans);
    font-weight: 600;
    line-height: 1.25;
    color: var(--text-primary);
  }

  /* Accessible focus style */
  :focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: 3px;
  }

  /* Skip to main content — visually hidden until focused */
  .skip-link {
    position: absolute;
    top: -100%;
    left: var(--space-4);
    background: var(--accent);
    color: #0d1117;
    padding: var(--space-2) var(--space-4);
    border-radius: 0 0 6px 6px;
    font-weight: 600;
    font-size: var(--text-sm);
    z-index: 200;
    transition: top 0.1s ease;
  }

  .skip-link:focus {
    top: 0;
  }
</style>