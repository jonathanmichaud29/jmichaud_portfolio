---
/**
 * TechArticleLayout.astro
 *
 * Layout for tech-article typed entries.
 *
 * CSS migration: post-layout.css, post-prose.css, and tech-article.css
 * have been dissolved into Tailwind utility classes inline on each element.
 * No external stylesheet imports remain in this layout.
 */

import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import { getArticleSchema, getBreadcrumbSchema } from "../lib/schema";
import { SITE } from "../config/site";

interface Props {
  post: CollectionEntry<"blog"> & { data: { type: "tech-article" } };
  series: CollectionEntry<"series"> | null;
}

const { post, series } = Astro.props;
const {
  title,
  description,
  publishedAt,
  updatedAt,
  readingTime,
  proficiencyLevel,
  dependencies,
  ogImage,
  canonicalUrl: canonicalOverride,
  noindex,
} = post.data;

const canonicalUrl = canonicalOverride ?? `${SITE.url}/blog/${post.id}`;

const articleSchema = getArticleSchema(post, series, canonicalUrl);

const breadcrumbItems = [
  { name: "Blog", path: "/blog" },
  ...(series
    ? [{ name: series.data.title, path: `/series/${series.data.slug}` }]
    : []),
  { name: title, path: `/blog/${post.id}` },
];
const breadcrumbSchema = getBreadcrumbSchema(breadcrumbItems);

// Proficiency level → label + Tailwind color classes
const levelConfig = {
  beginner: {
    label: "Beginner",
    class:
      "text-[#58a6ff] bg-[rgba(88,166,255,0.1)] border-[rgba(88,166,255,0.25)]",
  },
  intermediate: {
    label: "Intermediate",
    class: "text-accent bg-[rgba(63,185,80,0.1)] border-[rgba(63,185,80,0.25)]",
  },
  expert: {
    label: "Expert",
    class:
      "text-[#f78166] bg-[rgba(247,129,102,0.1)] border-[rgba(247,129,102,0.25)]",
  },
} as const;

const level = proficiencyLevel ? levelConfig[proficiencyLevel] : null;
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
  noindex={noindex}
  ogType="article"
  articlePublishedTime={publishedAt.toISOString()}
  articleModifiedTime={(updatedAt ?? publishedAt).toISOString()}
  schemaNodes={[articleSchema, breadcrumbSchema]}
>
  <div class="max-w-[var(--width-prose)] mx-auto px-6">
    <!-- Breadcrumb -->
    <nav
      class="flex items-center flex-wrap gap-2 font-mono text-xs text-text-muted py-8 pb-6"
      aria-label="Breadcrumb"
    >
      <a
        href="/"
        class="text-text-muted hover:text-accent transition-colors duration-150"
        >{SITE.name}</a
      >
      <span class="text-bg-border" aria-hidden="true">/</span>
      <a
        href="/blog"
        class="text-text-muted hover:text-accent transition-colors duration-150"
        >Blog</a
      >
      {
        series && (
          <>
            <span class="text-bg-border" aria-hidden="true">
              /
            </span>
            <a
              href={`/series/${series.data.slug}`}
              class="text-text-muted hover:text-accent transition-colors duration-150"
            >
              {series.data.title}
            </a>
          </>
        )
      }
      <span class="text-bg-border" aria-hidden="true">/</span>
      <span
        aria-current="page"
        class="text-text-primary max-w-[32ch] whitespace-nowrap overflow-hidden text-ellipsis"
        >{title}</span
      >
    </nav>

    <article>
      <!-- Post header -->
      <header class="pb-8 border-b border-bg-border mb-8">
        <h1
          class="text-[clamp(1.5rem,4vw,2.25rem)] font-semibold leading-[1.15] tracking-[-0.02em] mb-4"
        >
          {title}
        </h1>
        <p class="text-lg text-text-muted leading-[1.6] mb-6 max-w-[60ch]">
          {description}
        </p>

        <!-- Meta row -->
        <div
          class="flex items-center flex-wrap gap-3 text-xs text-text-muted font-mono"
        >
          <time datetime={publishedAt.toISOString()}>
            {
              publishedAt.toLocaleDateString("en-CA", {
                year: "numeric",
                month: "short",
                day: "numeric",
              })
            }
          </time>
          {
            updatedAt && (
              <>
                <span class="text-bg-border">·</span>
                <span>
                  Updated{" "}
                  <time datetime={updatedAt.toISOString()}>
                    {updatedAt.toLocaleDateString("en-CA", {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                    })}
                  </time>
                </span>
              </>
            )
          }
          {
            readingTime !== undefined && (
              <>
                <span class="text-bg-border">·</span>
                <span>{readingTime} min read</span>
              </>
            )
          }
          {
            level && (
              <>
                <span class="text-bg-border">·</span>
                <span
                  class={`font-mono text-xs rounded px-2 py-px font-medium border ${level.class}`}
                >
                  {level.label}
                </span>
              </>
            )
          }
        </div>

        <!-- Dependencies row -->
        {
          dependencies && dependencies.length > 0 && (
            <div
              class="flex items-center flex-wrap gap-2 mt-4"
              aria-label="Requirements"
            >
              <span class="font-mono text-xs text-text-muted uppercase tracking-[0.08em] mr-1">
                Requires
              </span>
              <ul class="flex flex-wrap gap-2" role="list">
                {dependencies.map((dep) => (
                  <li class="font-mono text-xs text-accent bg-[rgba(63,185,80,0.1)] border border-[rgba(63,185,80,0.2)] rounded px-2 py-0.5 whitespace-nowrap">
                    {dep}
                  </li>
                ))}
              </ul>
            </div>
          )
        }
      </header>

      <!-- Post body — prose styles from @tailwindcss/typography,
           Shiki + token overrides handled in global.css -->
      <div class="prose prose-invert max-w-none pb-24">
        <slot />
      </div>
    </article>
  </div>
</BaseLayout>
